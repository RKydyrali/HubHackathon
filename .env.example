# Root env values are read by the Telegram bot during local dev. Convex runtime
# secrets must also be configured on the Convex deployment (dashboard or CLI).
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev

# Convex HTTP site URL for /v1/bot/*, not the .cloud client URL used by web.
CONVEX_SITE_URL=https://your-deployment.convex.site
BOT_SHARED_SECRET=replace-me
# Optional HTTP-date (RFC 7231) for Sunset header on legacy /bot/* only, e.g. Wed, 11 Nov 2026 23:59:59 GMT
# BOT_HTTP_LEGACY_SUNSET=

OPENROUTER_API_KEY=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_COMPLEX_MODEL=openai/gpt-4o
OPENROUTER_EMBEDDING_MODEL=text-embedding-3-small
TELEGRAM_BOT_TOKEN=replace-me

# Web env lives in web/.env.local. Copy web/.env.example there and set:
# VITE_CONVEX_URL=https://your-deployment.convex.cloud
